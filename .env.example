# ── Backend (backend/.env) ────────────────────────────────────────────────────

# PostgreSQL — Supabase o Neon
# DATABASE_URL: conexión con pooler (Supabase: puerto 6543, ?pgbouncer=true) — la usa la app
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# DIRECT_URL: conexión directa (Supabase: puerto 5432) — la usa Prisma para migraciones
# Con Neon puedes repetir aquí la misma cadena de DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# JWT — cambia por una cadena aleatoria larga
JWT_SECRET="cambia_esto_por_un_secreto_muy_largo_y_seguro"

# Nodemailer — cuenta Gmail (activa "contraseñas de aplicación")
MAIL_USER="tucorreo@gmail.com"
MAIL_PASS="contraseña_de_aplicación"

# Gemini API — https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."

# JSON.pe — consulta DNI (100 créditos gratis)
JSONPE_TOKEN="tu_token_jsonpe"

# Cloudinary — subida de imágenes
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# Puerto del backend
PORT=4000

# CORS — origen(es) del frontend permitidos (separa varios con comas)
FRONTEND_URL="http://localhost:5173"

# ── Frontend (frontend/.env) ──────────────────────────────────────────────────
VITE_API_URL="http://localhost:4000"
